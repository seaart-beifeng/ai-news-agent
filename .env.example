# OpenAI 或 OpenAI-compatible 服务的 API Key。
# 为空时不会调用模型，日报会使用本地规则生成短摘要。
OPENAI_API_KEY=

# 用于总结、筛选和打分的模型名称。
# 官方 OpenAI 可用类似 gpt-5.5；如果使用自建/第三方网关，填网关支持的模型名。
OPENAI_MODEL=gpt-5.5

# 模型服务基础地址，不含最后的 /responses。
# 官方 OpenAI 默认是 https://api.openai.com/v1
# 自建或第三方 OpenAI-compatible 网关示例：https://your-domain.example.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：完整覆盖 Responses API endpoint。
# 如果填写，会优先使用这个地址；否则使用 OPENAI_BASE_URL + /responses。
OPENAI_RESPONSES_URL=

# 企业微信群机器人 Webhook，用于推送日报。
# 为空时不会推送到企业微信。
WECOM_WEBHOOK_URL=

# NewsAPI.org 的 API Key。
# 只有 config.json 里 newsapi.enabled=true 且这里有 key 时才会抓 NewsAPI。
NEWSAPI_KEY=

# GitHub Personal Access Token。可选但建议配置。
# 不配置时 GitHub 匿名 API 很容易 rate limit，导致无法抓最近 commits/releases。
GITHUB_TOKEN=
